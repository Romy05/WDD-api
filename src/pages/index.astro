---
import {
	fetchSpotifyArtistsByGenre,
	fetchSpotifyTrackByArtist,
	fetchSuggestedGamesBySearch
} from '../api/index.js';
import Song from '../components/Song/Song.astro';

const artistSearch = await fetchSpotifyArtistsByGenre('pop', 20, 10);
const artists = artistSearch.artists.items;

const songs = await Promise.all(artists.map(async (artist) => {
	return await fetchSpotifyTrackByArtist(artist.name);
}));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
	{
		songs.map(song => {
			return <Song song={song} key={song.id}/>
		})
	}

	<input type="text" />
	</body>
</html>

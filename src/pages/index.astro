---
import { fetchSpotifySongsByGenre, fetchSuggestedGamesBySearch } from '../api/index.js';
import Song from '../components/Song/Song.astro';

const search = await fetchSpotifySongsByGenre('hiphop');
const songs = search.tracks.items;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
	{
		songs.map(song => {
			return <Song song={song} key={song.id}/>
		})
	}

	<input type="text" />
	</body>
</html>

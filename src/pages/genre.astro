---
export const prerender = false;

import { fetchSongs } from "../api";
import SongList from '../components/SongList/SongList.astro'
import MainLayout from '../layouts/MainLayout.astro';

import '../style/index.css';

let genre = Astro.url.searchParams.get("genre");
let songs = [];

if (genre) {
    songs = await fetchSongs(genre);
    console.log(songs, 'songs')
    Astro.cookies.set('currentGenre', genre);
    const songsToSave = songs.map(song => {
        return {
            id: song.id,
            name: song.name,
            artists: [{name: song.artists[0].name}],
            album: {
                images: [{url: song.album.images[0].url}]
            }
        }
    })
    Astro.cookies.set('currentSongs', JSON.stringify(songsToSave));
} else {
    genre = Astro.cookies.get('currentGenre')?.value;
    const cookieSongs = Astro.cookies.get('currentSongs')?.value;
    songs = JSON.parse(cookieSongs || '[]');
}

console.log("Actief genre:", genre, songs);

---


<MainLayout title="Suggestions">
    <SongList genre={genre} songs={songs} />
</MainLayout>

<!--https://www.answeroverflow.com/m/1157809781357154355 voor de definevars-->
<script define:vars={{ songs }}>
    localStorage.setItem('generated-songs', JSON.stringify(songs));
</script>